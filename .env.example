# Gaff - environment reference
#
# This file documents every variable the app and its tooling read. At runtime
# the values come from Doppler (the `gaff` project, `dev` / `prd` configs) and
# are injected by `doppler run` / the Cloudflare Worker secret sync - NOT from
# a committed file. Use this as the checklist of what to put in Doppler.
#
# Source of truth for the app schema: src/lib/env.ts (Zod-validated).

# ── Required: database ───────────────────────────────────────────────────────
# Neon Postgres pooled connection string.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# ── Required: auth (Better Auth + Cloudflare Access) ─────────────────────────
# 32+ char random string used to sign sessions.
BETTER_AUTH_SECRET=
# Canonical app origin, no trailing slash (e.g. https://gaff.example.com).
BETTER_AUTH_URL=https://gaff.example.com
# 64-char hex AUD tag of your Cloudflare Access application.
CLOUDFLARE_ACCESS_AUD=
# Your Cloudflare Access team domain, full https URL.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# ── Required: external APIs ──────────────────────────────────────────────────
# Zyte API key - Zoopla scraping.
ZYTE_API_KEY=
# Anthropic key (sk-ant-…) - Claude listing enrichment.
ANTHROPIC_API_KEY=
# EPC Open Data token, raw "email:token" value - EPC certificate lookups.
EPC_OPENDATA_TOKEN=
# Google Maps browser key - Maps JS, Places Autocomplete, client Directions.
GOOGLE_MAPS_API_KEY=

# ── Required: Trigger.dev ────────────────────────────────────────────────────
# Trigger.dev secret key for task execution.
TRIGGER_SECRET_KEY=
# Trigger.dev project ref (proj_…). Read by trigger.config.ts.
TRIGGER_PROJECT_REF=proj_REPLACE_ME

# ── Optional: degrade gracefully when unset ──────────────────────────────────
# Unrestricted server-side Maps key for enrichment tasks (falls back to
# GOOGLE_MAPS_API_KEY with a Referer hack if absent).
GOOGLE_MAPS_SERVER_KEY=
# TfL Unified API key - lifts rate limits on transit lookups (anonymous works).
TFL_APP_KEY=
# logo.dev publishable token (pk_…) - brand logos on nearby-place chips.
LOGODEV_TOKEN=
# Resend API key - sending match + digest emails.
RESEND_API_KEY=
# Verified Resend sender, e.g. "Gaff <gaff@updates.example.com>". Falls back to
# a no-reply on the BETTER_AUTH_URL host when unset.
EMAIL_FROM=

# ── Optional: R2 photo cache (managed by `t-stack provision` → Doppler) ──────
# Cloudflare object storage for cached listing photos. Photos fall back to the
# original portal URLs when these are unset.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Local tooling (not app secrets) ──────────────────────────────────────────
# Doppler scope for the package.json scripts. Defaults to the repo dir (".")
# after `doppler setup`; set to an isolated path like ~/.t-stack/orgs/<org>
# if you keep multiple project scopes.
# DOPPLER_SCOPE=.
