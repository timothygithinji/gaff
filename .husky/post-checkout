#!/usr/bin/env sh

# post-checkout args:
#   $1 = previous HEAD
#   $2 = new HEAD
#   $3 = 1 if a branch checkout, 0 if a file checkout

# Only fire on branch checkouts.
[ "$3" = "0" ] && exit 0

if bun scripts/validation/branch-name.ts >/dev/null 2>&1; then
  exit 0
fi

# Bogus branch — print the full rejection message, then auto-revert to the
# previous branch (we don't delete the bogus branch, so any work-in-progress
# is preserved; user just can't *stay* on it). git ignores post-checkout's
# exit code, so the revert IS the enforcement.
bad=$(git rev-parse --abbrev-ref HEAD)
prev=$(git rev-parse --abbrev-ref "@{-1}" 2>/dev/null || echo "")

echo
bun scripts/validation/branch-name.ts "$bad" 2>&1
echo

if [ -n "$prev" ] && [ "$prev" != "HEAD" ] && [ "$prev" != "$bad" ]; then
  echo "Reverting to '$prev'. The branch '$bad' is preserved locally; rename or delete it:"
  echo "  git branch -m feat/your-slug   # rename"
  echo "  git branch -D $bad             # delete"
  echo
  git checkout "$prev" >/dev/null 2>&1
fi

exit 1
