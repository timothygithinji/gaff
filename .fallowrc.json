{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    // TanStack Start finds these automatically, but list them so fallow
    // doesn't mistake them for unused files when its built-in plugin runs.
    "src/router.tsx",
    "src/routes/**/*.tsx",
    // Trigger.dev loads task files from `./src/trigger` per
    // `trigger.config.ts`'s `dirs` setting — fallow can't see that.
    "src/trigger/**/*.ts",
    // CLI scripts run directly via `bun scripts/<name>.ts`.
    "scripts/**/*.ts",
    // Vitest discovers these via `*.test.ts` glob.
    "tests/**/*.{ts,tsx}",
    // Single-file configs loaded by their respective CLIs.
    "openapi-ts.config.ts",
    "t-stack.config.ts",
    "trigger.config.ts",
    // Loaded by `@better-auth/cli generate`, not imported anywhere.
    "src/lib/auth.config.ts"
  ],
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3,
    "ignore": [
      "**/generated/**" // postcodes.io + EPC clients are generated by openapi-ts
    ]
  },
  "health": {
    // Generated code is regenerated from source schemas, so its
    // complexity is not ours to refactor: openapi-ts emits the
    // postcodes.io + EPC clients under `generated/`, and TanStack
    // Router emits `routeTree.gen.ts`. Exclude both from complexity
    // analysis so the findings list stays actionable.
    "ignore": ["**/generated/**", "**/*.gen.ts"]
  },
  // Real deps that are referenced indirectly (string configs, shell invocations
  // from scripts, biome `extends`) — fallow's static analyzer can't see those.
  "ignoreDependencies": [
    "@hey-api/client-fetch", // plugin string in openapi-ts.config.ts
    "@better-auth/cli", // invoked by `bun run auth:generate` via bunx
    "ultracite" // biome.json `extends` preset
  ],
  // shadcn/ui primitives ship a full subcomponent set per file; we use a
  // subset, but the rest stays so re-running `bunx shadcn add <name>`
  // doesn't keep adding components we already have. `cva` variant
  // exports (button, badge) are part of the primitive contract too.
  // Generated openapi-ts clients have the same shape — keep them whole.
  "ignoreExports": [
    {
      "file": "src/components/ui/**",
      "exports": ["*"]
    },
    {
      "file": "src/lib/api-clients/**/generated/**",
      "exports": ["*"]
    }
  ],
  // Default modules export their full helper surface even when only one
  // consumer happens to be inside the same file (defaults, internal-use
  // constants, type aliases referenced by the same module's signatures).
  // Knip's same behavior; keeps the findings list focused on truly
  // cross-file dead code.
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unused-dependencies": "warn"
  }
}
