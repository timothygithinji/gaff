{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["ultracite"],
  "formatter": { "enabled": false },
  "files": {
    "ignore": [
      "dist",
      "node_modules",
      "coverage",
      ".wrangler",
      "drizzle",
      "src/routeTree.gen.ts",
      "src/lib/api-clients/epc/generated",
      "src/lib/api-clients/postcodes-io/generated",
      ".fallowrc.json",
      "wrangler.jsonc"
    ]
  },
  "javascript": {
    "globals": [
      "Bun",
      "KVNamespace",
      "R2Bucket",
      "DurableObject",
      "DurableObjectNamespace",
      "ExportedHandler",
      "ExecutionContext",
      "Fetcher",
      "Queue",
      "AnalyticsEngineDataset"
    ]
  },
  "overrides": [
    {
      "include": ["scripts/**", ".claude/**", "tests/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noConsoleLog": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "include": ["src/routes/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
