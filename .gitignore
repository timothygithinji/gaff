# Dependencies
node_modules/
.pnpm-store/
.bun/

# Build output
dist/
build/
out/
.output/
*.tsbuildinfo

# Cloudflare Workers / Wrangler local state.
# Note: Doppler is the only source of dev secrets — we don't keep a
# .dev.vars.example, since `doppler secrets` is the canonical listing.
.wrangler/
.dev.vars
.dev.vars.*

# Vite / Cloudflare dev caches
.vite/

# Test + coverage
coverage/
*.lcov

# Local secrets and env files (Doppler is the source of truth in dev)
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# Drizzle Studio
.drizzle/

# Pulumi — Pulumi.yaml and Pulumi.<stack>.yaml are committed stack configs.
# Only the local credential cache should be ignored.
infra/cloudflare/.pulumi/
infra/cloudflare/node_modules/

# Misc tooling caches
.turbo/
.cache/
.parcel-cache/
.next/
.nuxt/

# Generated by `bun run dev` / smoke runs
/tmp/
gaff-dev.log
gaff-dev.pid
